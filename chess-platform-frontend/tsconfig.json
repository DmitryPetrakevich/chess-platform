{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "resolveJsonModule": true,

    "strict": false,                   
    "noImplicitAny": false,            
    "strictNullChecks": false,          
    "strictFunctionTypes": false,       
    "strictBindCallApply": false,     
    "alwaysStrict": false,              
    "useUnknownInCatchVariables": false, 

    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,

    "allowJs": true,
    "checkJs": false,
    "forceConsistentCasingInFileNames": true,

    /* 🧭 Пути */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },

  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue", "src/components/game/composables/useDragAndDrop.js", "src/components/game/composables/useSquareClick.js", "src/components/game/composables/useBoardOrientation.js", "src/store", "src/composables/useBoardOrientation.js", "src/composables/useDragAndDrop.ts", "src/composables/useSquareClick.ts"]
}
